# Copiar a .env para demos MCP (liviano). Ajustar secretos localmente — no commitear.
#
# Ver: docs/DEMO-GUIA.md (índice) · docs/DEMO-HELPER.md (chuleta) · docs/DEMO-MCP-GUIDE.md

GITHUB_TOKEN=

# Perfil demo: ~1 LLM/PR, sin workflow contextual ni evidence merge (salvo que sobreescribas abajo)
PR_ANALYZER_PROFILE=demo

AI_ENABLED=true

# Una sola vía LLM basta (OpenRouter o OpenAI)
# OPENROUTER_API_KEY=
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Jira opcional en demo (dejar vacío = menos I/O)
# JIRA_URL=
# JIRA_USERNAME=
# JIRA_API_TOKEN=

# Confluence off en demo por defecto
# CONFLUENCE_BASE_URL=
# CONFLUENCE_TOKEN=

# MCP (stdio por defecto; SSE si exponés red)
# MCP_TRANSPORT=sse
# MCP_PORT=8080
# MCP_AUTH_SECRET=

# domain_context.md en la raíz del repo analizador (no del monorepo bajo prueba)
# DOMAIN_CONTEXT_PATH=domain_context.md
